# --- Database (required) ---
# DATABASE_URL  = app runtime connection (used by the deployed app).
# DIRECT_URL    = migrations/seed connection (drizzle-kit). Optional locally; on
#                 a pooled host it must be the SESSION-mode connection.
#
# Supabase FREE tier (deploying on Vercel): the direct db.<ref>.supabase.co host
# is IPv6-only, which Vercel can't reach — so use the IPv4 POOLER for both:
#   DATABASE_URL -> Transaction pooler, port 6543  (app runtime; prepare:false handled in code)
#   DIRECT_URL   -> Session pooler,     port 5432  (drizzle-kit migrations/seed)
# Find these in Supabase: Project → Connect → "Connection pooling".
#
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DIRECT_URL=""

# --- Auth.js / NextAuth v5 (required) ---
# Generate with: openssl rand -base64 33
AUTH_SECRET="replace-me"

# Google OAuth client credentials (Google Cloud Console > Credentials > OAuth client ID, type "Web application")
# Authorized redirect URI (dev):  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod): https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID="xxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="replace-me"

# Comma-separated Google emails that are auto-promoted to active Admin on first login.
# Everyone else signs in inactive and must be approved by an Admin in Settings.
ADMIN_EMAILS="you@gmail.com"

# Production only: the canonical URL of the deployment (Auth.js uses it to build callback URLs).
# AUTH_URL="https://your-domain.com"
